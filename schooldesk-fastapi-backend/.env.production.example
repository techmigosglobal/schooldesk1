SCHOOLDESK_ENVIRONMENT=production
POSTGRES_USER=schooldesk
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=schooldesk_fastapi
REDIS_PASSWORD=replace-with-strong-redis-password
SCHOOLDESK_DATABASE_URL=postgresql+psycopg://schooldesk:replace-with-strong-postgres-password@postgres:5432/schooldesk_fastapi
SCHOOLDESK_REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0
SCHOOLDESK_JWT_SECRET_KEY=replace-with-long-random-jwt-secret
SCHOOLDESK_SEED_ON_START=false
SCHOOLDESK_REDIS_HEALTH_ENABLED=true
SCHOOLDESK_CORS_ALLOW_ORIGINS=https://replace-with-flutter-web-origin
SCHOOLDESK_CORS_ALLOW_ORIGIN_REGEX=
