SCHOOLDESK_ENVIRONMENT=local
SCHOOLDESK_DATABASE_URL=postgresql+psycopg://schooldesk:schooldesk@postgres:5432/schooldesk_fastapi
SCHOOLDESK_REDIS_URL=redis://redis:6379/0
SCHOOLDESK_JWT_SECRET_KEY=change-this-local-secret
SCHOOLDESK_SEED_ON_START=true
SCHOOLDESK_REDIS_HEALTH_ENABLED=true
SCHOOLDESK_CORS_ALLOW_ORIGINS=
SCHOOLDESK_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
