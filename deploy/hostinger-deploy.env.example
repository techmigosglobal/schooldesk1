# Copy this file to deploy/hostinger-deploy.env for local operator defaults.
# Do not store production passwords here.

HOSTINGER_SSH_HOST=187.127.157.43
HOSTINGER_SSH_USER=root
HOSTINGER_SSH_KEY=$HOME/.ssh/schooldesk_hostinger_vps
HOSTINGER_EXPECTED_ED25519_SHA256=SHA256:ZqqHqq502eUL+j3N5ccdlfVD7nxPUBkGchftOj40atA

HOSTINGER_REMOTE_ROOT=/opt/schooldesk_V1
HOSTINGER_COMPOSE_FILE=docker-compose.hostinger-traefik.yml
HOSTINGER_COMPOSE_SERVICE=go-api
# Keep empty for routine API deploys. Set to "notification-worker" only after
# the VPS has Firebase credentials and the push compose profile is enabled.
HOSTINGER_COMPOSE_EXTRA_SERVICES=
HOSTINGER_COMPOSE_PROFILES=
HOSTINGER_API_HEALTH_URL=https://schooldesk-api.187.127.157.43.nip.io/health
HOSTINGER_API_LOGIN_URL=https://schooldesk-api.187.127.157.43.nip.io/api/v1/auth/login
HOSTINGER_BACKUP_ROOT=/root/schooldesk-backups

# Optional login smoke. Export the password in your shell instead of storing it:
# HOSTINGER_SMOKE_LOGIN_USERNAME=principal
# export HOSTINGER_SMOKE_LOGIN_PASSWORD='<set-in-current-shell>'
