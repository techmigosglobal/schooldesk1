PORT=8080
APP_MODE=api
ENVIRONMENT=production
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters
ALLOWED_ORIGINS=https://your-frontend-domain.com

POSTGRES_DB=schooldesk
POSTGRES_USER=schooldesk
POSTGRES_PASSWORD=replace_with_a_strong_postgres_password

REDIS_PASSWORD=replace_with_a_strong_redis_password
REDIS_DB=0

MIGRATE_ON_START=false
SEED_ON_START=false
DISABLE_PUBLIC_REGISTRATION=true
USE_POSTGRES_ONLY=true
REQUIRE_HTTPS_API_BASE_URL=true

# Push notifications stay disabled until Firebase credentials are mounted on the VPS.
ENABLE_FCM_PUSH=false
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_FILE=/opt/schooldesk-secrets/firebase-service-account.json

API_HOST=api.yourdomain.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# Observability overlay. Keep bind addresses on localhost unless Grafana is
# placed behind a protected reverse proxy.
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_a_strong_grafana_password
